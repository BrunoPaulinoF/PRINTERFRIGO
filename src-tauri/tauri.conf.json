{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PRINTERFRIGO",
  "version": "0.2.0",
  "identifier": "br.com.kyberfrigo.printerfrigo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PRINTERFRIGO",
        "width": 980,
        "height": 760,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1RTY0RDhFMzFFRTY0NzUKUldSMVpPNHhqazNtSldmQnhFNkdBZmRNSXRaQmEyc0FXWDlwWTBGazdqa2FZaGY2cHpNZllSZzIK",
      "endpoints": [
        "https://github.com/BrunoPaulinoF/PRINTERFRIGO/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
